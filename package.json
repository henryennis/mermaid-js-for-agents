{
  "name": "mermaid-js-for-agents",
  "version": "0.1.0",
  "description": "A Tessl/Agent Skills/Pi/Claude/Codex package that teaches AI agents to create and repair Mermaid.js diagrams.",
  "type": "module",
  "license": "MIT",
  "author": "Mermaid.js for Agents contributors",
  "homepage": "https://github.com/henryennis/mermaid-js-for-agents#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henryennis/mermaid-js-for-agents.git"
  },
  "bugs": {
    "url": "https://github.com/henryennis/mermaid-js-for-agents/issues"
  },
  "keywords": [
    "agent-skills",
    "tessl",
    "pi-package",
    "claude-code-plugin",
    "codex-plugin",
    "mermaid",
    "diagrams-as-code",
    "ai-agents"
  ],
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.18"
  },
  "files": [
    "skills/",
    "docs/",
    "rules/",
    "scripts/",
    "evals/",
    "data/",
    "tile.json",
    ".claude-plugin/",
    ".codex-plugin/",
    ".agents/plugins/marketplace.json",
    ".pi/",
    ".github/agents/",
    ".github/workflows/mermaid-skill-maintenance.md",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "pi": {
    "skills": [
      "./skills"
    ],
    "image": "https://img.shields.io/badge/Mermaid.js-for%20Agents-7c3aed"
  },
  "scripts": {
    "prepare": "node scripts/prepare-husky.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . && npm run lint:skills && npm run lint:workflows && npm run lint:harnesses",
    "lint:skills": "node scripts/lint-skills.mjs",
    "lint:workflows": "node scripts/lint-agentic-workflows.mjs",
    "lint:harnesses": "node scripts/validate-harness-manifests.mjs",
    "test": "vitest run",
    "check": "npm run format:check && npm run lint && npm test && npm run validate:mermaid && npm run discover:evals:check && npm run smoke:pack",
    "generate": "node scripts/update-mermaid-reference.mjs",
    "discover:evals": "node scripts/discover-eval-opportunities.mjs",
    "discover:evals:check": "node scripts/discover-eval-opportunities.mjs --check",
    "validate:mermaid": "npm run validate:mermaid:parse",
    "validate:mermaid:static": "node scripts/validate-mermaid-examples.mjs",
    "validate:mermaid:parse": "node scripts/validate-mermaid-examples.mjs --parse",
    "smoke:pack": "node scripts/validate-harness-manifests.mjs --pack",
    "audit:ci": "npm audit --audit-level=high",
    "sbom": "npm sbom --sbom-format=cyclonedx --sbom-type=library > sbom.cdx.json",
    "install:local": "node scripts/install-local.mjs",
    "agentic:compile": "gh aw compile",
    "tessl:lint": "tessl skill lint .",
    "tessl:review": "tessl skill review skills/mermaid-diagrams",
    "tessl:eval": "tessl eval run ."
  },
  "lint-staged": {
    "*.{js,mjs,json,md,yml,yaml}": "prettier --write",
    "skills/**/SKILL.md": "node scripts/lint-skills.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.26.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "jsdom": "27.2.0",
    "lint-staged": "^15.5.1",
    "mermaid": "11.14.0",
    "prettier": "^3.5.3",
    "vitest": "^3.1.3"
  },
  "overrides": {
    "uuid": "14.0.0"
  }
}
